<div class="bg-[#F0EFEB]/85 min-h-screen">
  <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8 py-8 lg:py-12">
    <h1 class="text-3xl font-bold text-gray-900 mb-1">My Cart</h1>
    <hr class="border-gray-200 mb-8">

    {%- if cart.item_count == 0 -%}
      <div class="bg-white rounded-lg p-16 text-center">
        <svg class="w-16 h-16 mx-auto mb-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 3h2l.4 2M7 13h10l4-8H5.4m1.6 8l-1.5 6h13M10 21a1 1 0 1 1-2 0 1 1 0 0 1 2 0zm9 0a1 1 0 1 1-2 0 1 1 0 0 1 2 0z"/>
        </svg>
        <p class="text-gray-500 text-lg mb-6">Your cart is empty.</p>
        <a href="{{ routes.all_products_collection_url }}"
           class="inline-block bg-orange-500 text-white font-semibold tracking-widest uppercase text-sm px-8 py-3 hover:bg-orange-600 transition-colors duration-200">
          Continue Shopping
        </a>
      </div>
    {%- else -%}

      <div class="flex flex-col lg:flex-row gap-6 items-start">
        <div class="w-full lg:flex-[1.8]">
          <div class="bg-white rounded-lg shadow-sm">

            <div class="px-6 pt-6 pb-4 border-b border-gray-100">
              <h2 class="text-base font-semibold text-gray-800">
                My Cart ({{ cart.item_count }})
              </h2>
            </div>

            {%- for item in cart.items -%}
              <div class="{% unless forloop.last %}border-b border-gray-100{% endunless %}">
                <div class="flex gap-4 px-6 py-5">

                  <a href="{{ item.url }}" class="flex-none w-20 h-20 sm:w-24 sm:h-24 rounded overflow-hidden bg-gray-50 border border-gray-100">
                    {%- if item.image -%}
                      <img
                        src="{{ item.image | image_url: width: 200 }}"
                        alt="{{ item.image.alt | escape | default: item.product.title | escape }}"
                        width="200" height="200"
                        loading="lazy"
                        decoding="async"
                        class="w-full h-full object-cover object-center"
                      >
                    {%- else -%}
                      <div class="w-full h-full flex items-center justify-center bg-gray-100">
                        <svg class="w-8 h-8 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                        </svg>
                      </div>
                    {%- endif -%}
                  </a>

                  <div class="flex-1 min-w-0">

                    <div class="flex items-start justify-between gap-3">
                      <div class="flex-1 min-w-0">

                        {%- comment -%} Title {%- endcomment -%}
                        <a href="{{ item.url }}" class="text-sm font-semibold text-gray-900 hover:text-orange-500 transition-colors duration-150 leading-snug block pr-2">
                          {{ item.product.title }}
                        </a>

                        {%- if item.vendor != blank -%}
                          <p class="text-xs text-gray-400 mt-0.5">{{ item.vendor }}</p>
                        {%- endif -%}

                        {%- unless item.variant.title == 'Default Title' -%}
                          <p class="text-xs text-gray-500 mt-1">
                            {%- for option in item.variant.options -%}
                              {%- assign opt_name = item.product.options[forloop.index0] -%}
                              <span class="font-medium">{{ opt_name }}:</span> {{ option }}
                              {%- unless forloop.last -%}&nbsp;&nbsp;|&nbsp;&nbsp;{%- endunless -%}
                            {%- endfor -%}
                          </p>
                        {%- endunless -%}

                      </div>

                      <div class="flex-none flex items-center gap-0 border border-gray-800 rounded" role="group" aria-label="Quantity for {{ item.product.title | escape }}">

                        <form action="{{ routes.cart_change_url }}" method="post" class="flex">
                          <input type="hidden" name="id" value="{{ item.key }}">
                          <input type="hidden" name="quantity" value="{{ item.quantity | minus: 1 }}">
                          <button
                            type="submit"
                            class="w-8 h-8 flex items-center justify-center bg-gray-900 text-white hover:bg-gray-700 transition-colors duration-150 text-lg font-medium leading-none focus-visible:outline focus-visible:outline-2 focus-visible:outline-orange-500"
                            aria-label="Decrease quantity"
                            {%- if item.quantity <= 1 -%}disabled class="w-8 h-8 flex items-center justify-center bg-gray-300 text-gray-500 cursor-not-allowed text-lg font-medium leading-none"{%- endif -%}
                          >
                            −
                          </button>
                        </form>

                        <span class="w-9 h-8 flex items-center justify-center text-sm font-semibold text-gray-800 bg-white border-x border-gray-800 select-none" aria-label="Current quantity">
                          {{ item.quantity }}
                        </span>

                        <form action="{{ routes.cart_change_url }}" method="post" class="flex">
                          <input type="hidden" name="id" value="{{ item.key }}">
                          <input type="hidden" name="quantity" value="{{ item.quantity | plus: 1 }}">
                          <button
                            type="submit"
                            class="w-8 h-8 flex items-center justify-center bg-gray-900 text-white hover:bg-gray-700 transition-colors duration-150 text-lg font-medium leading-none focus-visible:outline focus-visible:outline-2 focus-visible:outline-orange-500"
                            aria-label="Increase quantity"
                          >
                            +
                          </button>
                        </form>

                      </div>
                    </div>

                    <div class="flex items-center justify-between mt-3">

                      <div class="flex items-baseline gap-2">
                        {%- comment -%} Compare price (strikethrough) {%- endcomment -%}
                        {%- if item.variant.compare_at_price > item.variant.price -%}
                          <span class="text-sm text-gray-400 line-through">
                            {{ item.variant.compare_at_price | money }}
                          </span>
                        {%- endif -%}

                        {%- comment -%} Actual price {%- endcomment -%}
                        <span class="text-base font-bold text-gray-900">
                          {{ item.variant.price | money }}
                        </span>

                        {%- if item.variant.compare_at_price > item.variant.price -%}
                          {%- assign saving = item.variant.compare_at_price | minus: item.variant.price | times: 100 | divided_by: item.variant.compare_at_price -%}
                          <span class="text-sm font-semibold text-orange-500">{{ saving }}% OFF</span>
                        {%- endif -%}
                      </div>

                      <form action="{{ routes.cart_change_url }}" method="post">
                        <input type="hidden" name="id" value="{{ item.key }}">
                        <input type="hidden" name="quantity" value="0">
                        <button
                          type="submit"
                          class="flex items-center gap-1 text-xs text-gray-400 hover:text-red-500 transition-colors duration-150 focus-visible:outline focus-visible:outline-2 focus-visible:outline-orange-500"
                          aria-label="Remove {{ item.product.title | escape }} from cart"
                        >
                          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                          </svg>
                          Remove
                        </button>
                      </form>

                    </div>
                  </div>
                </div>
              </div>
            {%- endfor -%}

          </div>
        </div>
        <div class="w-full lg:w-[340px] xl:w-[360px] flex-none flex flex-col gap-4">
          <div class="bg-white rounded-lg shadow-sm p-5">
            <h3 class="text-base font-semibold text-gray-800 mb-4">Coupons</h3>
            <form action="{{ routes.cart_url }}" method="post" class="flex gap-2">
              <label for="coupon-code" class="sr-only">Coupon code</label>
              <input
                type="text"
                id="coupon-code"
                name="checkout[coupon]"
                placeholder="Coupon code"
                class="flex-1 border border-gray-200 rounded text-sm px-3 py-2.5 text-gray-700 placeholder-gray-400 focus:outline-none focus:border-orange-400 focus:ring-1 focus:ring-orange-400 min-w-0"
                autocomplete="off"
              >
              <button
                type="submit"
                class="flex-none bg-gray-900 text-white text-[10px] font-bold tracking-widest uppercase px-4 py-2.5 rounded hover:bg-gray-700 transition-colors duration-200 whitespace-nowrap focus-visible:outline focus-visible:outline-2 focus-visible:outline-orange-500"
              >
                Apply Now
              </button>
            </form>
          </div>

          <div class="bg-white rounded-lg shadow-sm p-5">
            <h3 class="text-base font-semibold text-gray-800 mb-5">Your Order</h3>

            <div class="flex justify-between items-center mb-1">
              <span class="text-sm text-gray-500">Subtotal ({{ cart.item_count }} item{%- if cart.item_count != 1 -%}s{%- endif -%})</span>
              <span class="text-sm font-semibold text-gray-900">{{ cart.total_price | money }}</span>
            </div>
            <hr class="border-dashed border-gray-200 my-4">

            <div class="mb-4">
              <p class="text-sm font-semibold text-gray-700 mb-3">Delivery</p>
              <div class="flex flex-col gap-2">
                <label class="flex items-center gap-2.5 cursor-pointer group">
                  <input
                    type="radio"
                    name="delivery_type"
                    value="delivery"
                    checked
                    class="w-4 h-4 accent-orange-500 cursor-pointer"
                  >
                  <span class="text-sm text-gray-700 group-hover:text-gray-900 transition-colors">
                    Delivery
                    {%- if section.settings.delivery_fee != blank -%}
                      : <span class="font-medium">{{ section.settings.delivery_fee }}</span>
                    {%- endif -%}
                  </span>
                </label>
                <label class="flex items-center gap-2.5 cursor-pointer group">
                  <input
                    type="radio"
                    name="delivery_type"
                    value="pickup"
                    class="w-4 h-4 accent-orange-500 cursor-pointer"
                  >
                  <span class="text-sm text-gray-700 group-hover:text-gray-900 transition-colors">Pick Up</span>
                </label>
              </div>
            </div>
            <hr class="border-gray-100 my-4">

            {%- if section.settings.service_fee != blank -%}
              <div class="flex justify-between items-center mb-3">
                <span class="text-sm text-gray-500">Service Fee</span>
                <span class="text-sm font-medium text-gray-800">{{ section.settings.service_fee }}</span>
              </div>
            {%- endif -%}

            {%- if cart.total_tax > 0 -%}
              <div class="flex justify-between items-center mb-3">
                <span class="text-sm text-gray-500">Tax</span>
                <span class="text-sm font-medium text-gray-800">{{ cart.total_tax | money }}</span>
              </div>
            {%- elsif section.settings.tax_label != blank -%}
              <div class="flex justify-between items-center mb-3">
                <span class="text-sm text-gray-500">Tax</span>
                <span class="text-sm font-medium text-gray-800">{{ section.settings.tax_label }}</span>
              </div>
            {%- endif -%}

            <hr class="border-gray-100 my-4">

            <div class="flex justify-between items-center mb-6">
              <span class="text-base font-bold text-gray-900">Total Payable</span>
              <span class="text-base font-bold text-gray-900">{{ cart.total_price | money }}</span>
            </div>

            <form action="{{ routes.checkout_url }}" method="post">
              <button
                type="submit"
                name="checkout"
                class="w-full bg-orange-500 hover:bg-orange-600 active:bg-orange-700 text-white font-bold tracking-widest uppercase text-sm py-4 transition-colors duration-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-orange-500"
              >
                Proceed to Checkout
              </button>
            </form>

            <a
              href="{{ routes.all_products_collection_url }}"
              class="block text-center text-xs text-gray-400 hover:text-orange-500 transition-colors duration-200 mt-3"
            >
              ← Continue Shopping
            </a>

          </div>

        </div>
      </div>

    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Cart Page",
  "settings": [
    {
      "type": "header",
      "content": "Order Summary"
    },
    {
      "type": "text",
      "id": "delivery_fee",
      "label": "Delivery fee label",
      "default": "$7.99",
      "info": "Display only — use Shopify shipping rates for actual charges"
    },
    {
      "type": "text",
      "id": "service_fee",
      "label": "Service fee label",
      "info": "e.g. $1.50 — leave blank to hide"
    },
    {
      "type": "text",
      "id": "tax_label",
      "label": "Tax label (fallback)",
      "info": "Shown when cart tax is zero — e.g. 'Calculated at checkout'"
    }
  ],
  "presets": [
    {
      "name": "Cart Page"
    }
  ]
}
{% endschema %}
