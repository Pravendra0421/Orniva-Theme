{%- assign current_product = product -%}

<section class="w-full bg-white font-sans">
  <div class="max-w-[1400px] mx-auto px-5 md:px-10 lg:px-16 py-10 lg:py-16">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 xl:gap-20">

      <div class="flex flex-col gap-4">

        <div class="relative w-full overflow-hidden aspect-square lg:aspect-[4/3]" style="background-color: {{ section.settings.image_bg }};">
          <img id="main-product-image"
            src="{{ current_product.featured_image | image_url: width: 1200 }}"
            alt="{{ current_product.title | escape }}"
            width="1200" height="1200"
            class="w-full h-full object-contain object-center p-8 transition-opacity duration-300">

          {%- if current_product.compare_at_price > current_product.price -%}
            <span class="absolute top-4 left-4 bg-black text-white text-[10px] font-bold tracking-[0.15em] uppercase px-3 py-1.5">Sale</span>
          {%- endif -%}

          {%- if current_product.images.size > 1 -%}
            <button id="prev-img-btn" aria-label="Previous image"
              class="absolute left-3 top-1/2 -translate-y-1/2 w-9 h-9 flex items-center justify-center bg-white/80 hover:bg-white border border-gray-200 hover:border-gray-400 transition-all duration-200 text-gray-700 hover:text-black text-xl leading-none">‹</button>
            <button id="next-img-btn" aria-label="Next image"
              class="absolute right-3 top-1/2 -translate-y-1/2 w-9 h-9 flex items-center justify-center bg-white/80 hover:bg-white border border-gray-200 hover:border-gray-400 transition-all duration-200 text-gray-700 hover:text-black text-xl leading-none">›</button>
          {%- endif -%}
        </div>

        {%- if section.settings.show_thumbnails and current_product.images.size > 1 -%}
          <div class="flex gap-2 overflow-x-auto pb-1">
            {%- for image in current_product.images -%}
              <button type="button" data-src="{{ image | image_url: width: 1200 }}"
                class="thumb-btn flex-shrink-0 w-20 h-20 border-2 transition-all duration-200 overflow-hidden {% if forloop.first %}border-black{% else %}border-transparent hover:border-gray-300{% endif %}"
                style="background-color: {{ section.settings.image_bg }};"
                aria-label="View image {{ forloop.index }}">
                <img src="{{ image | image_url: width: 200 }}" alt="{{ current_product.title | escape }} – {{ forloop.index }}"
                  width="200" height="200" class="w-full h-full object-contain object-center p-1" loading="lazy">
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}

      </div>
      <div class="flex flex-col">

        {%- if section.settings.show_breadcrumb -%}
          <nav class="text-[11px] tracking-widest uppercase text-gray-400 mb-5 flex items-center gap-2">
            <a href="/" class="hover:text-black transition-colors duration-200">Home</a>
            <span>/</span>
            {%- if current_product.collections.first -%}
              <a href="{{ current_product.collections.first.url }}" class="hover:text-black transition-colors duration-200">{{ current_product.collections.first.title }}</a>
              <span>/</span>
            {%- endif -%}
            <span class="text-gray-600 truncate max-w-[160px]">{{ current_product.title }}</span>
          </nav>
        {%- endif -%}

        {%- if section.settings.show_vendor and current_product.vendor != blank -%}
          <p class="text-[11px] tracking-widest uppercase text-gray-400 mb-2">{{ current_product.vendor }}</p>
        {%- endif -%}

        <h1 class="text-[28px] md:text-[36px] font-semibold text-black leading-tight tracking-tight mb-4">
          {{ current_product.title }}
        </h1>

        {%- if section.settings.show_rating -%}
          {%- assign review_count = current_product.metafields.reviews.rating_count | default: 0 -%}
          {%- assign rating = current_product.metafields.reviews.rating.value | default: 0 -%}
          <div class="flex items-center gap-3 mb-5">
            <div class="flex items-center gap-0.5" aria-label="Rating: {{ rating }} out of 5">
              {%- for i in (1..5) -%}
                <svg class="w-4 h-4 {% if i <= rating %}text-amber-400{% else %}text-gray-200{% endif %}" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              {%- endfor -%}
            </div>
            {%- if review_count > 0 -%}
              <span class="text-[13px] text-gray-500 underline underline-offset-2 cursor-pointer hover:text-black transition-colors duration-200">({{ review_count }} customer review{% if review_count != 1 %}s{% endif %})</span>
            {%- else -%}
              <span class="text-[13px] text-gray-400">(No reviews yet)</span>
            {%- endif -%}
          </div>
        {%- endif -%}

        <div class="flex items-baseline gap-3 mb-6 pb-6 border-b border-gray-100">
          {%- if current_product.compare_at_price > current_product.price -%}
            <span class="text-2xl font-bold text-red-500">{{ current_product.price | money }}</span>
            <span class="text-lg text-gray-400 line-through">{{ current_product.compare_at_price | money }}</span>
            {%- assign savings_pct = current_product.compare_at_price | minus: current_product.price | times: 100 | divided_by: current_product.compare_at_price -%}
            <span class="text-[11px] font-bold tracking-wider uppercase bg-red-50 text-red-500 px-2 py-0.5">Save {{ savings_pct }}%</span>
          {%- else -%}
            <span class="text-2xl font-bold text-black">{{ current_product.price | money }}</span>
          {%- endif -%}
        </div>

        {%- if section.settings.show_sku and current_product.selected_or_first_available_variant.sku != blank -%}
          <p class="text-[12px] text-gray-400 mb-4">SKU: <span class="text-gray-600 font-medium">{{ current_product.selected_or_first_available_variant.sku }}</span></p>
        {%- endif -%}

        {%- if current_product.description != blank -%}
          <div class="text-[14px] text-gray-600 leading-relaxed mb-7 line-clamp-4">
            {{ current_product.description | strip_html | truncate: 300 }}
          </div>
        {%- endif -%}

        {%- unless current_product.has_only_default_variant -%}
          {%- for option in current_product.options_with_values -%}
            <div class="mb-5">
              <p class="text-[11px] font-bold tracking-[0.15em] uppercase text-gray-900 mb-2.5">{{ option.name }}</p>
              <div class="flex flex-wrap gap-2">
                {%- for value in option.values -%}
                  <label class="cursor-pointer">
                    <input type="radio" name="option-{{ option.position }}" value="{{ value | escape }}" class="sr-only peer" {% if forloop.first %}checked{% endif %}>
                    <span class="inline-block px-4 py-2 text-[12px] font-medium tracking-wide border border-gray-200 peer-checked:border-black peer-checked:bg-black peer-checked:text-white hover:border-gray-400 transition-all duration-200">{{ value }}</span>
                  </label>
                {%- endfor -%}
              </div>
            </div>
          {%- endfor -%}
        {%- endunless -%}

        <div class="flex flex-col sm:flex-row gap-3 mb-6">
          <div class="flex items-center border border-gray-200 h-12 w-fit">
            <button id="qty-minus" type="button" aria-label="Decrease quantity"
              class="w-11 h-full flex items-center justify-center text-xl text-gray-500 hover:text-black hover:bg-gray-50 transition-all duration-200 select-none">−</button>
            <input id="qty-input" type="number" name="quantity" value="1" min="1"
              class="w-12 h-full text-center text-[14px] font-medium border-x border-gray-200 focus:outline-none">
            <button id="qty-plus" type="button" aria-label="Increase quantity"
              class="w-11 h-full flex items-center justify-center text-xl text-gray-500 hover:text-black hover:bg-gray-50 transition-all duration-200 select-none">+</button>
          </div>
          <button type="submit" form="product-form-{{ current_product.id }}"
            class="flex-1 h-12 bg-black text-white text-[12px] font-bold tracking-[0.2em] uppercase px-8 hover:bg-gray-900 active:scale-[0.98] transition-all duration-200">
            {{ section.settings.cart_button_label }}
          </button>
        </div>

        <form id="product-form-{{ current_product.id }}" method="post" action="/cart/add" class="hidden">
          <input type="hidden" name="id" value="{{ current_product.selected_or_first_available_variant.id }}">
          <input type="hidden" name="quantity" id="form-qty" value="1">
        </form>

        {%- if section.settings.show_wishlist or section.settings.show_compare -%}
          <div class="flex items-center gap-6 mb-7 pb-7 border-b border-gray-100">
            {%- if section.settings.show_wishlist -%}
              <a href="/wishlist" class="flex items-center gap-2 text-[12px] text-gray-500 hover:text-black transition-colors duration-200 group">
                <svg class="w-4 h-4 group-hover:fill-black transition-all duration-200" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/>
                </svg>
                Browse Wishlist
              </a>
            {%- endif -%}
            {%- if section.settings.show_compare -%}
              <a href="/compare" class="flex items-center gap-2 text-[12px] text-gray-500 hover:text-black transition-colors duration-200">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5"/>
                </svg>
                Add to Compare
              </a>
            {%- endif -%}
          </div>
        {%- endif -%}

        <div class="space-y-2 mb-6 text-[13px] text-gray-500">
          {%- if section.settings.show_collections and current_product.collections.size > 0 -%}
            <p>
              <span class="font-semibold text-gray-800">Categories:</span>
              {%- for collection in current_product.collections -%}
                <a href="{{ collection.url }}" class="hover:text-black transition-colors duration-200 underline underline-offset-2">{{ collection.title }}</a>{% unless forloop.last %}, {% endunless %}
              {%- endfor -%}
            </p>
          {%- endif -%}
          {%- if section.settings.show_tags and current_product.tags.size > 0 -%}
            <p>
              <span class="font-semibold text-gray-800">Tags:</span>
              {%- for tag in current_product.tags -%}
                <a href="/collections/all/{{ tag | handle }}" class="hover:text-black transition-colors duration-200 underline underline-offset-2">{{ tag }}</a>{% unless forloop.last %}, {% endunless %}
              {%- endfor -%}
            </p>
          {%- endif -%}
        </div>

        {%- if section.settings.show_share -%}
          <div class="flex items-center gap-4">
            <span class="text-[11px] font-bold tracking-[0.15em] uppercase text-gray-400">Share</span>
            <a href="https://www.facebook.com/sharer/sharer.php?u={{ shop.url }}{{ current_product.url }}" target="_blank" rel="noopener" aria-label="Share on Facebook"
              class="w-8 h-8 flex items-center justify-center border border-gray-200 text-gray-400 hover:border-blue-500 hover:text-blue-600 transition-all duration-200">
              <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
            <a href="https://twitter.com/intent/tweet?url={{ shop.url }}{{ current_product.url }}&text={{ current_product.title | url_encode }}" target="_blank" rel="noopener" aria-label="Share on Twitter"
              class="w-8 h-8 flex items-center justify-center border border-gray-200 text-gray-400 hover:border-sky-400 hover:text-sky-500 transition-all duration-200">
              <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.748l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </a>
            <a href="https://pinterest.com/pin/create/button/?url={{ shop.url }}{{ current_product.url }}&media={{ current_product.featured_image | image_url: width: 600 }}" target="_blank" rel="noopener" aria-label="Share on Pinterest"
              class="w-8 h-8 flex items-center justify-center border border-gray-200 text-gray-400 hover:border-red-500 hover:text-red-600 transition-all duration-200">
              <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.162-.105-.949-.2-2.403.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 01.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24.009 12.017 24.009c6.624 0 11.99-5.367 11.99-11.988C24.007 5.367 18.641.001 12.017.001z"/></svg>
            </a>
            <a href="https://www.linkedin.com/shareArticle?mini=true&url={{ shop.url }}{{ current_product.url }}" target="_blank" rel="noopener" aria-label="Share on LinkedIn"
              class="w-8 h-8 flex items-center justify-center border border-gray-200 text-gray-400 hover:border-blue-700 hover:text-blue-800 transition-all duration-200">
              <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </a>
          </div>
        {%- endif -%}

      </div>
    </div>
    <div class="mt-16 lg:mt-24">
      <div class="flex border-b border-gray-200 mb-10">
        <button id="tab-desc" type="button"
          class="px-6 py-3 text-[13px] font-bold tracking-[0.1em] uppercase text-red-500 border-b-2 border-red-500 -mb-px transition-all duration-200"
          onclick="switchTab('description')">{{ section.settings.tab_description_label }}</button>
        <button id="tab-rev" type="button"
          class="px-6 py-3 text-[13px] font-bold tracking-[0.1em] uppercase text-gray-400 border-b-2 border-transparent hover:text-gray-700 -mb-px transition-all duration-200"
          onclick="switchTab('reviews')">{{ section.settings.tab_reviews_label }} ({{ current_product.metafields.reviews.rating_count | default: 0 }})</button>
      </div>
      <div id="panel-description" class="prose prose-sm max-w-none text-gray-600 leading-relaxed text-[14px]">
        {{ current_product.description }}
      </div>
      <div id="panel-reviews" class="hidden">
        <p class="text-gray-500 text-[14px]">Reviews widget renders here via your review app block.</p>
      </div>
    </div>
    {%- if section.settings.show_related -%}
      {%- assign related_collection = current_product.collections.first -%}
      {%- if related_collection -%}
        {%- assign related_limit = section.settings.related_count -%}
        {%- assign shown = 0 -%}

        {%- capture related_items -%}
          {%- for rp in related_collection.products -%}
            {%- unless rp.id == current_product.id -%}
              {%- if shown < related_limit -%}
                <div class="group relative flex flex-col">
                  <a href="{{ rp.url }}" class="block relative overflow-hidden mb-4 aspect-square" style="background-color: {{ section.settings.image_bg }};">
                    {%- if rp.compare_at_price > rp.price -%}
                      <span class="absolute top-3 left-3 z-10 bg-black text-white text-[9px] font-bold tracking-[0.15em] uppercase px-2.5 py-1">Sale</span>
                    {%- endif -%}
                    <img src="{{ rp.featured_image | image_url: width: 600 }}" alt="{{ rp.title | escape }}"
                      width="600" height="600" loading="lazy"
                      class="w-full h-full object-contain object-center p-6 transition-transform duration-500 group-hover:scale-105">
                    <div class="absolute inset-0 bg-black/0 group-hover:bg-black/5 transition-all duration-300"></div>
                    <div class="absolute bottom-0 left-0 right-0 translate-y-full group-hover:translate-y-0 transition-transform duration-300">
                      <span class="block w-full bg-black text-white text-[10px] font-bold tracking-[0.2em] uppercase text-center py-3">View Product</span>
                    </div>
                  </a>
                  <div class="flex flex-col gap-1.5">
                    {%- if rp.collections.first -%}
                      <p class="text-[10px] tracking-widest uppercase text-gray-400">{{ rp.collections.first.title }}</p>
                    {%- endif -%}
                    {%- assign rp_rating = rp.metafields.reviews.rating.value | default: 0 -%}
                    <div class="flex items-center gap-0.5">
                      {%- for i in (1..5) -%}
                        <svg class="w-3 h-3 {% if i <= rp_rating %}text-amber-400{% else %}text-gray-200{% endif %}" fill="currentColor" viewBox="0 0 20 20">
                          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                        </svg>
                      {%- endfor -%}
                    </div>
                    <a href="{{ rp.url }}" class="text-[14px] font-medium text-black hover:text-gray-600 transition-colors duration-200 leading-snug line-clamp-2">{{ rp.title }}</a>
                    <div class="flex items-baseline gap-2 mt-0.5">
                      {%- if rp.compare_at_price > rp.price -%}
                        <span class="text-[15px] font-bold text-red-500">{{ rp.price | money }}</span>
                        <span class="text-[13px] text-gray-400 line-through">{{ rp.compare_at_price | money }}</span>
                      {%- else -%}
                        <span class="text-[15px] font-bold text-black">{{ rp.price | money }}</span>
                      {%- endif -%}
                    </div>
                  </div>
                </div>
                {%- assign shown = shown | plus: 1 -%}
              {%- endif -%}
            {%- endunless -%}
          {%- endfor -%}
        {%- endcapture -%}

        {%- if related_items contains 'href' -%}
          <div class="mt-20 lg:mt-28">
            <div class="text-center mb-10">
              <h2 class="text-2xl lg:text-3xl font-semibold text-black tracking-tight mb-3">{{ section.settings.related_heading }}</h2>
              <div class="flex items-center justify-center gap-1">
                <span class="block w-8 h-px bg-red-400"></span>
                <span class="block w-2 h-2 rounded-full bg-red-400"></span>
                <span class="block w-8 h-px bg-red-400"></span>
              </div>
            </div>
            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-5 lg:gap-8">
              {{ related_items }}
            </div>
          </div>
        {%- endif -%}

      {%- endif -%}
    {%- endif -%}

  </div>
</section>

<script>
(function () {
  var mainImg   = document.getElementById('main-product-image');
  var thumbBtns = document.querySelectorAll('.thumb-btn');
  var images    = Array.from(thumbBtns).map(function(b){ return b.dataset.src; });
  var currentIdx = 0;

  function setActive(idx) {
    currentIdx = (idx + images.length) % images.length;
    if (mainImg) {
      mainImg.style.opacity = '0';
      setTimeout(function(){ mainImg.src = images[currentIdx]; mainImg.style.opacity = '1'; }, 150);
    }
    thumbBtns.forEach(function(b, i){
      b.classList.toggle('border-black', i === currentIdx);
      b.classList.toggle('border-transparent', i !== currentIdx);
    });
  }

  thumbBtns.forEach(function(btn, i){ btn.addEventListener('click', function(){ setActive(i); }); });

  var prevBtn = document.getElementById('prev-img-btn');
  var nextBtn = document.getElementById('next-img-btn');
  if (prevBtn) prevBtn.addEventListener('click', function(){ setActive(currentIdx - 1); });
  if (nextBtn) nextBtn.addEventListener('click', function(){ setActive(currentIdx + 1); });

  var qtyInput = document.getElementById('qty-input');
  var formQty  = document.getElementById('form-qty');
  var minusBtn = document.getElementById('qty-minus');
  var plusBtn  = document.getElementById('qty-plus');

  function syncQty(val) {
    var n = Math.max(1, parseInt(val) || 1);
    if (qtyInput) qtyInput.value = n;
    if (formQty)  formQty.value  = n;
  }

  if (minusBtn) minusBtn.addEventListener('click', function(){ syncQty(parseInt(qtyInput.value) - 1); });
  if (plusBtn)  plusBtn.addEventListener('click',  function(){ syncQty(parseInt(qtyInput.value) + 1); });
  if (qtyInput) qtyInput.addEventListener('change', function(){ syncQty(this.value); });

  window.switchTab = function(tab) {
    var panels  = { description: 'panel-description', reviews: 'panel-reviews' };
    var tabBtns = { description: 'tab-desc',          reviews: 'tab-rev'       };
    Object.keys(panels).forEach(function(key) {
      var panel  = document.getElementById(panels[key]);
      var btn    = document.getElementById(tabBtns[key]);
      var active = key === tab;
      if (panel) panel.classList.toggle('hidden', !active);
      if (btn) {
        btn.classList.toggle('text-red-500',       active);
        btn.classList.toggle('border-red-500',     active);
        btn.classList.toggle('text-gray-400',      !active);
        btn.classList.toggle('border-transparent', !active);
      }
    });
  };
})();
</script>

