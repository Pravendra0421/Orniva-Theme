{%- assign r1 = section.id | append: '_r1' -%}
{%- assign r2 = section.id | append: '_r2' -%}
{%- assign r3 = section.id | append: '_r3' -%}
<section
  id="hero-{{ section.id }}"
  class="relative flex flex-col md:flex-row w-full overflow-hidden"
  style="height:{{ section.settings.section_height }}px; font-family:'Outfit',sans-serif;"
>

  <div class="relative w-full md:w-2/3 h-1/2 md:h-full overflow-hidden flex-shrink-0">

    <input type="radio" id="{{ r1 }}" name="hero_{{ section.id }}" class="peer/r1 hidden" checked>
    <input type="radio" id="{{ r2 }}" name="hero_{{ section.id }}" class="peer/r2 hidden">
    <input type="radio" id="{{ r3 }}" name="hero_{{ section.id }}" class="peer/r3 hidden">

    {% for block in section.blocks %}
      {% if block.type == 'slide' %}

        <div
          class="
            absolute inset-0 w-full h-full
            transition-opacity duration-700 ease-in-out
            opacity-0 pointer-events-none
            {% if forloop.index == 1 %}peer-checked/r1:opacity-100 peer-checked/r1:pointer-events-auto
            {% elsif forloop.index == 2 %}peer-checked/r2:opacity-100 peer-checked/r2:pointer-events-auto
            {% elsif forloop.index == 3 %}peer-checked/r3:opacity-100 peer-checked/r3:pointer-events-auto
            {% endif %}
          "
          {{ block.shopify_attributes }}
        >
          {% if block.settings.slide_image != blank %}
            <img
                src="{{ block.settings.slide_image | image_url: width: 800 }}"
                srcset="
                    {{ block.settings.slide_image | image_url: width: 400 }} 400w,
                    {{ block.settings.slide_image | image_url: width: 800 }} 800w,
                    {{ block.settings.slide_image | image_url: width: 1200 }} 1200w
                "
                sizes="(max-width: 768px) 100vw, 66vw"
                alt="{{ block.settings.slide_image.alt | escape }}"
                class="absolute inset-0 w-full h-full object-cover"
                loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                {% if forloop.first %}fetchpriority="high"{% endif %}
                >
          {% else %}
            <div class="absolute inset-0 w-full h-full bg-stone-200 flex items-center justify-center">
              {{ 'lifestyle-1' | placeholder_svg_tag: 'w-full h-full object-cover opacity-20' }}
            </div>
          {% endif %}
          <div class="absolute inset-0 bg-gradient-to-br from-black/40 via-black/10 to-transparent z-10"></div>
          <div class="absolute top-0 left-0 z-20 p-8 md:p-10 max-w-[320px] md:max-w-sm">
            {% if block.settings.eyebrow != blank %}
              <p class="text-[10px] uppercase tracking-[0.25em] text-white/65 mb-3">
                {{ block.settings.eyebrow }}
              </p>
            {% endif %}
            {% if block.settings.heading != blank %}
              <h2
                class="text-[2rem] md:text-[2.6rem] leading-[1.15] text-white mb-3"
                style="font-family:'Cormorant Garamond',serif; font-weight:300;"
              >
                {{ block.settings.heading }}
              </h2>
            {% endif %}
            {% if block.settings.subtext != blank %}
              <p class="text-[13px] text-white/70 mb-7 leading-relaxed">
                {{ block.settings.subtext }}
              </p>
            {% endif %}
            {% if block.settings.button_label != blank %}
              <a
                href="{{ block.settings.button_url }}"
                class="inline-block px-7 py-[11px] text-[10px] uppercase tracking-[0.2em] text-white border border-white/75 hover:bg-white hover:text-neutral-900 transition-all duration-300"
              >
                {{ block.settings.button_label }}
              </a>
            {% endif %}
          </div>

        </div>
      {% endif %}
    {% endfor %}

    <div class="absolute bottom-6 left-0 right-0 z-30 flex items-center px-8 md:px-10">
      <div class="flex items-center gap-[7px]">
        {% for block in section.blocks %}
          {% if block.type == 'slide' %}
            <label
              for="{% if forloop.index == 1 %}{{ r1 }}{% elsif forloop.index == 2 %}{{ r2 }}{% elsif forloop.index == 3 %}{{ r3 }}{% endif %}"
              class="
                block h-[3px] rounded-full cursor-pointer transition-all duration-300
                {% if forloop.index == 1 %}
                  w-6 bg-white/30 peer-checked/r1:w-10 peer-checked/r1:bg-white
                {% elsif forloop.index == 2 %}
                  w-6 bg-white/30 peer-checked/r2:w-10 peer-checked/r2:bg-white
                {% elsif forloop.index == 3 %}
                  w-6 bg-white/30 peer-checked/r3:w-10 peer-checked/r3:bg-white
                {% endif %}
              "
            ></label>
          {% endif %}
        {% endfor %}
      </div>
      <div class="ml-auto flex items-center gap-2">

        <label
          for="{{ section.id }}_r{{ slide_count }}"
          class="flex items-center justify-center w-10 h-10 rounded-full bg-white/18 hover:bg-white/35 cursor-pointer transition-colors duration-200 border border-white/20"
          aria-label="Previous slide"
        >
          <svg width="15" height="15" viewBox="0 0 15 15" fill="none">
            <path d="M9.5 11.5L5.5 7.5l4-4" stroke="white" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </label>
        <label
          for="{{ r2 }}"
          class="flex items-center justify-center w-10 h-10 rounded-full bg-neutral-900/80 hover:bg-neutral-900 cursor-pointer transition-colors duration-200"
          aria-label="Next slide"
        >
          <svg width="15" height="15" viewBox="0 0 15 15" fill="none">
            <path d="M5.5 3.5l4 4-4 4" stroke="white" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </label>

      </div>
    </div>
  </div>
  <div class="relative w-full md:w-1/3 h-1/2 md:h-full overflow-hidden flex-shrink-0">

    {% if section.settings.video_shopify != blank %}
      {{
        section.settings.video_shopify
        | video_tag:
          autoplay: true,
          loop: true,
          muted: true,
          playsinline: true,
          class: 'absolute inset-0 w-full h-full object-cover'
      }}
    {% elsif section.settings.video_url != blank %}
      <video
        class="absolute inset-0 w-full h-full object-cover"
        src="{{ section.settings.video_url }}"
        autoplay muted loop playsinline preload="metadata"
      ></video>
    {% else %}
      <div class="absolute inset-0 w-full h-full bg-neutral-800 flex items-center justify-center">
        <svg class="w-12 h-12 text-white/15" fill="currentColor" viewBox="0 0 24 24">
          <path d="M8 5v14l11-7z"/>
        </svg>
      </div>
    {% endif %}

    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-black/10 z-10"></div>

    {% if section.settings.video_heading != blank %}
      <div class="absolute top-0 left-0 right-0 z-20 p-7 md:p-8">
        <h3
          class="text-[1.6rem] md:text-[2rem] text-white leading-[1.2]"
          style="font-family:'Cormorant Garamond',serif; font-weight:300;"
        >
          {{ section.settings.video_heading }}
        </h3>
      </div>
    {% endif %}
    <div class="absolute bottom-0 left-0 right-0 z-20 p-7 md:p-8">
      {% if section.settings.video_eyebrow != blank %}
        <p class="text-[10px] uppercase tracking-[0.25em] text-white/55 mb-1">
          {{ section.settings.video_eyebrow }}
        </p>
      {% endif %}
      {% if section.settings.video_discount != blank %}
        <p
          class="text-[3rem] md:text-[3.5rem] text-white leading-none mb-5"
          style="font-family:'Cormorant Garamond',serif; font-weight:300;"
        >
          {{ section.settings.video_discount }}
        </p>
      {% endif %}
      {% if section.settings.video_button_label != blank %}
        <a
          href="{{ section.settings.video_button_url }}"
          class="inline-block px-6 py-[10px] text-[10px] uppercase tracking-[0.2em] text-white border border-white/65 hover:bg-white hover:text-neutral-900 transition-all duration-300"
        >
          {{ section.settings.video_button_label }}
        </a>
      {% endif %}
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Hero – Carousel + Video",
  "tag": "section",
  "class": "hero-section",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "section_height",
      "min": 400,
      "max": 900,
      "step": 20,
      "unit": "px",
      "label": "Section Height (desktop)",
      "default": 620
    },
    {
      "type": "header",
      "content": "Right Panel — Video"
    },
    {
      "type": "video",
      "id": "video_shopify",
      "label": "Video (Shopify Hosted)",
      "info": "Recommended. Upload via Shopify Admin → Content → Files."
    },
    {
      "type": "url",
      "id": "video_url",
      "label": "Video URL (External .mp4)",
      "info": "Only used if no Shopify-hosted video is set above."
    },
    {
      "type": "text",
      "id": "video_heading",
      "label": "Video Heading",
      "default": "Refined Silhouettes Designed For Modern Confidence"
    },
    {
      "type": "text",
      "id": "video_eyebrow",
      "label": "Offer Label",
      "default": "Shop The Look"
    },
    {
      "type": "text",
      "id": "video_discount",
      "label": "Discount / Highlight Text",
      "default": "50% Off"
    },
    {
      "type": "text",
      "id": "video_button_label",
      "label": "Button Label",
      "default": "Explore Now"
    },
    {
      "type": "url",
      "id": "video_button_url",
      "label": "Button URL"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Carousel Slide",
      "limit": 3,
      "settings": [
        {
          "type": "image_picker",
          "id": "slide_image",
          "label": "Slide Image"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow / Tag",
          "default": "New Arrivals"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Elevated Everyday Style"
        },
        {
          "type": "textarea",
          "id": "subtext",
          "label": "Subtext",
          "default": "Discover statement pieces that bring confidence and modern elegance."
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button Label",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "button_url",
          "label": "Button URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero – Carousel + Video",
      "blocks": [
        {
          "type": "slide",
          "settings": {
            "eyebrow": "New Arrivals",
            "heading": "Elevated Everyday Style",
            "subtext": "Discover statement pieces that bring confidence and modern elegance.",
            "button_label": "Shop Now"
          }
        },
        {
          "type": "slide",
          "settings": {
            "eyebrow": "This Season",
            "heading": "Effortless Modern Looks",
            "subtext": "Curated collections for the woman who moves with intention.",
            "button_label": "View All"
          }
        },
        {
          "type": "slide",
          "settings": {
            "eyebrow": "Exclusive Drop",
            "heading": "Statement Pieces, Quiet Power",
            "subtext": "Limited silhouettes crafted for those who need no introduction.",
            "button_label": "Discover"
          }
        }
      ]
    }
  ]
}
{% endschema %}
