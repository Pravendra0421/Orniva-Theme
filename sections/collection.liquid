<div class="bg-[#faf9f7] min-h-screen">
  {% paginate collection.products by section.settings.products_per_page %}
  <div class="relative w-full overflow-hidden border-b border-gray-200">
    {% if collection.image %}
      <div class="absolute inset-0">
        <img
          src="{{ collection.image | image_url: width: 1400 }}"
          alt="{{ collection.title }}"
          class="w-full h-full object-cover"
        >
        <div class="absolute inset-0 bg-white/70"></div>
      </div>
    {% else %}
      <div class="absolute inset-0 bg-[#f5f2ec]"></div>
    {% endif %}
    <div class="relative z-10 max-w-[1400px] mx-auto px-6 py-16">
      <h1 class="text-3xl md:text-5xl font-serif text-gray-900">
        {{ collection.title }}
      </h1>

      {% if collection.description %}
        <p class="mt-3 text-gray-600 max-w-xl">
          {{ collection.description | strip_html | truncatewords: 25 }}
        </p>
      {% endif %}

    </div>
  </div>
  <div class="max-w-[1400px] mx-auto px-6 py-6 flex justify-between items-center flex-wrap gap-4">
    
    <p class="text-sm text-gray-500">
      Showing {{ collection.products_count }} products
    </p>

    {% if section.settings.show_sort %}
      <form method="get">
        <select 
          name="sort_by"
          onchange="this.form.submit()"
          class="border border-gray-300 px-3 py-2 text-sm bg-white focus:outline-none focus:border-black"
        >
          <option value="manual" {% if collection.sort_by == 'manual' %}selected{% endif %}>Featured</option>
          <option value="best-selling" {% if collection.sort_by == 'best-selling' %}selected{% endif %}>Best Selling</option>
          <option value="title-ascending" {% if collection.sort_by == 'title-ascending' %}selected{% endif %}>A → Z</option>
          <option value="title-descending" {% if collection.sort_by == 'title-descending' %}selected{% endif %}>Z → A</option>
          <option value="price-ascending" {% if collection.sort_by == 'price-ascending' %}selected{% endif %}>Price: Low → High</option>
          <option value="price-descending" {% if collection.sort_by == 'price-descending' %}selected{% endif %}>Price: High → Low</option>
          <option value="created-descending" {% if collection.sort_by == 'created-descending' %}selected{% endif %}>Newest</option>
        </select>
      </form>
    {% endif %}

  </div>

  <div class="max-w-[1400px] mx-auto px-6 pb-16">

    {% if collection.products_count == 0 %}
      <div class="text-center py-20">
        <p class="text-gray-500">No products found.</p>
      </div>
    {% else %}

      <div class="grid gap-6
        grid-cols-2
        {% if section.settings.grid_columns == '3' %}
          md:grid-cols-3
        {% elsif section.settings.grid_columns == '4' %}
          md:grid-cols-3 lg:grid-cols-4
        {% endif %}
      ">

        {% for product in collection.products %}

          <div class="group bg-white rounded-lg overflow-hidden border border-gray-100 hover:shadow-md transition">

            <a href="{{ product.url }}">

              <!-- IMAGE -->
              <div class="aspect-[3/4] overflow-hidden bg-gray-100">
                {% if product.featured_image %}
                  <img
                    src="{{ product.featured_image | image_url: width: 500 }}"
                    alt="{{ product.title }}"
                    class="w-full h-full object-cover group-hover:scale-105 transition duration-500"
                  >
                {% endif %}
              </div>

              <!-- CONTENT -->
              <div class="p-4">

                <h3 class="text-sm font-medium text-gray-800 line-clamp-2">
                  {{ product.title }}
                </h3>

                {% if section.settings.show_vendor and product.vendor != blank %}
                  <p class="text-xs text-gray-400 mt-1">
                    {{ product.vendor }}
                  </p>
                {% endif %}

                <div class="mt-2 flex items-center gap-2">

                  <span class="text-base font-semibold text-gray-900">
                    {{ product.price | money }}
                  </span>

                  {% if product.compare_at_price > product.price %}
                    <span class="text-sm text-gray-400 line-through">
                      {{ product.compare_at_price | money }}
                    </span>
                  {% endif %}

                </div>

              </div>

            </a>

          </div>

        {% endfor %}

      </div>

    {% endif %}

    <!-- PAGINATION -->
    {% if paginate.pages > 1 %}
      <div class="flex justify-center mt-16 gap-2 flex-wrap">

        {% if paginate.previous %}
          <a href="{{ paginate.previous.url }}"
             class="px-4 py-2 border text-sm hover:bg-gray-100">
            Prev
          </a>
        {% endif %}

        {% for part in paginate.parts %}
          {% if part.is_link %}
            <a href="{{ part.url }}"
               class="px-3 py-2 border text-sm hover:bg-gray-100">
              {{ part.title }}
            </a>
          {% elsif part.title == paginate.current_page %}
            <span class="px-3 py-2 border bg-black text-white text-sm">
              {{ part.title }}
            </span>
          {% endif %}
        {% endfor %}

        {% if paginate.next %}
          <a href="{{ paginate.next.url }}"
             class="px-4 py-2 border text-sm hover:bg-gray-100">
            Next
          </a>
        {% endif %}

      </div>
    {% endif %}

  </div>

  {% endpaginate %}
</div>

{% schema %}
{
  "name": "Collection Products",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 16
    },
    {
      "type": "select",
      "id": "grid_columns",
      "label": "Columns on desktop",
      "options": [
        { "value": "2", "label": "2 columns" },
        { "value": "3", "label": "3 columns" },
        { "value": "4", "label": "4 columns" }
      ],
      "default": "4"
    },
    {
      "type": "checkbox",
      "id": "show_sort",
      "label": "Enable sorting",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Collection Product"
    }
  ]
}
{% endschema %}