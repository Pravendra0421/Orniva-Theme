<header class="w-full box-border bg-[#F0EFEB]/85 md:backdrop-blur-md shadow-sm sticky top-0 z-40">
  
  <div class="px-4 md:px-8 py-5 flex items-center justify-between font-sans">
    
    <div class="flex-1 flex items-center">
      
      <label for="mobile-sidebar-toggle" aria-label="Open Mobile Menu" class="md:hidden text-gray-900 hover:text-gray-500 transition-colors mr-4 shrink-0 cursor-pointer">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"></path>
        </svg>
      </label>

      <nav class="hidden md:flex items-center gap-4 lg:gap-8 text-xs lg:text-sm font-semibold tracking-wide text-gray-900">
        <a href="{{ section.settings.link_1_url }}" class="hover:text-gray-500 transition-colors whitespace-nowrap">
          {{ section.settings.link_1_text }}
        </a>
        <a href="{{ section.settings.link_2_url }}" class="hover:text-gray-500 transition-colors whitespace-nowrap">
          {{ section.settings.link_2_text }}
        </a>
        <a href="{{ section.settings.link_3_url }}" class="flex items-center gap-1 hover:text-gray-500 transition-colors whitespace-nowrap">
          {{ section.settings.link_3_text }}
          <svg class="w-4 h-4 mt-0.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
          </svg>
        </a>
        <a href="{{ section.settings.link_4_url }}" class="hover:text-gray-500 transition-colors whitespace-nowrap">
          {{ section.settings.link_4_text }}
        </a>
      </nav>
    </div>

    <div class="flex justify-center shrink-0 px-2">
      <a href="{{ routes.root_url }}" class="text-3xl lg:text-5xl font-serif text-black tracking-widest uppercase">
        {{ section.settings.company_name }}
      </a>
    </div>

    <div class="flex-1 flex justify-end items-center gap-4 lg:gap-6 text-gray-900">
      <button aria-label="Search" class="hover:text-gray-500 transition-colors shrink-0">
        <svg class="w-5 h-5 lg:w-6 lg:h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"></path>
        </svg>
      </button>

      <button aria-label="Profile" class="hover:text-gray-500 transition-colors shrink-0">
        <svg class="w-5 h-5 lg:w-6 lg:h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"></path>
        </svg>
      </button>

      <button aria-label="Cart" class="relative hover:text-gray-500 transition-colors shrink-0">
        <svg class="w-5 h-5 lg:w-6 lg:h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007zM8.625 10.5a.375.375 0 11-.75 0 .375.375 0 01.75 0zm7.5 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"></path>
        </svg>
        <span class="absolute -top-1.5 -right-2.5 bg-white text-black text-[9px] lg:text-[10px] font-bold px-[5px] py-[1px] rounded-full border border-gray-300">
          0
        </span>
      </button>
    </div>
    
  </div>
</header>

<input type="checkbox" id="mobile-sidebar-toggle" class="peer hidden" aria-hidden="true" />

<label for="mobile-sidebar-toggle" class="fixed inset-0 bg-black/40 z-[50] opacity-0 pointer-events-none transition-opacity duration-300 md:hidden peer-checked:opacity-100 peer-checked:pointer-events-auto cursor-pointer"></label>

<div class="fixed inset-y-0 left-0 w-4/5 max-w-sm bg-[#E5E4DE] z-[60] transform -translate-x-full peer-checked:translate-x-0 transition-transform duration-300 ease-in-out md:hidden flex flex-col shadow-2xl font-sans">
  
  <div class="px-6 py-5 flex items-center justify-between border-b border-gray-300">
    <a href="{{ routes.root_url }}" class="text-2xl font-serif text-black tracking-widest uppercase">
      {{ section.settings.company_name }}
    </a>
    
    <label for="mobile-sidebar-toggle" aria-label="Close Mobile Menu" class="text-gray-900 hover:text-gray-500 transition-colors cursor-pointer">
      <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </label>
  </div>

  <nav class="flex-1 overflow-y-auto py-6 px-6 flex flex-col space-y-6 text-base font-semibold tracking-wide text-gray-900">
    <a href="{{ section.settings.link_1_url }}" class="block hover:text-gray-500 transition-colors">
      {{ section.settings.link_1_text }}
    </a>
    <a href="{{ section.settings.link_2_url }}" class="block hover:text-gray-500 transition-colors">
      {{ section.settings.link_2_text }}
    </a>
    <a href="{{ section.settings.link_3_url }}" class="flex items-center justify-between hover:text-gray-500 transition-colors group">
      {{ section.settings.link_3_text }}
      <svg class="w-5 h-5 group-hover:-rotate-90 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"></path>
      </svg>
    </a>
    <a href="{{ section.settings.link_4_url }}" class="block hover:text-gray-500 transition-colors">
      {{ section.settings.link_4_text }}
    </a>
  </nav>

</div>

{% schema %}
{
  "name": "Custom Header",
  "settings": [
    {
      "type": "header",
      "content": "Logo Settings"
    },
    {
      "type": "text",
      "id": "company_name",
      "label": "Company Name",
      "default": "Orniva"
    },
    {
      "type": "header",
      "content": "Navigation Links"
    },
    {
      "type": "text",
      "id": "link_1_text",
      "label": "Link 1 Text",
      "default": "HOME"
    },
    {
      "type": "url",
      "id": "link_1_url",
      "label": "Link 1 URL"
    },
    {
      "type": "text",
      "id": "link_2_text",
      "label": "Link 2 Text",
      "default": "CATALOG"
    },
    {
      "type": "url",
      "id": "link_2_url",
      "label": "Link 2 URL"
    },
    {
      "type": "text",
      "id": "link_3_text",
      "label": "Link 3 Text",
      "default": "COLLECTIONS"
    },
    {
      "type": "url",
      "id": "link_3_url",
      "label": "Link 3 URL"
    },
    {
      "type": "text",
      "id": "link_4_text",
      "label": "Link 4 Text",
      "default": "CONTACT"
    },
    {
      "type": "url",
      "id": "link_4_url",
      "label": "Link 4 URL"
    },
    {
      "type": "header",
      "content": "Component Configuration"
    },
    {
      "type": "select",
      "id": "status",
      "label": "Status Type",
      "options": [
        {
          "value": "Pending",
          "label": "Pending"
        },
        {
          "value": "Approved",
          "label": "Approved"
        }
      ],
      "default": "Pending"
    }
  ],
  "presets": [
    {
      "name": "Custom Header"
    }
  ]
}
{% endschema %}