<div class="w-full bg-white py-16 px-5 md:px-10 lg:px-16 max-w-[1500px] mx-auto font-sans">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8 mb-24">
            {%- for block in section.blocks -%}
            <div 
        class="promo-banner-{{ section.id }} relative w-full flex items-center p-10 lg:p-14 overflow-hidden group transition-all duration-300"
        style="
            height: {{ section.settings.mobile_height }}px;
        "
        {{ block.shopify_attributes }}
        >
        
        <div class="absolute inset-0 w-full h-full z-0 transition-transform duration-[1.5s] ease-out group-hover:scale-105" style="background-color: {{ block.settings.bg_color }};">
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 1200 | image_tag: alt: block.settings.heading, width: 1200, height: 1200, widths: '400,600,800,1200', sizes: '(max-width: 768px) 100vw, 50vw', loading: 'lazy', class: 'w-full h-full object-cover object-right lg:object-center' }}
          {%- endif -%}
        </div>

        <div class="relative z-10 w-full max-w-[280px] lg:max-w-[320px] text-center ">
          {%- if block.settings.eyebrow != blank -%}
            <p class="text-[10px] font-bold tracking-[0.15em] uppercase text-gray-900 mb-5">
              {{ block.settings.eyebrow }}
            </p>
          {%- endif -%}
          
          {%- if block.settings.heading != blank -%}
            <h3 class="text-3xl lg:text-[42px] font-medium text-black leading-[1.15] mb-4 tracking-tight">
              {{ block.settings.heading | newline_to_br }}
            </h3>
          {%- endif -%}
          
          {%- if block.settings.text != blank -%}
            <p class="text-[14px] text-gray-700 mb-10 leading-relaxed font-light">
              {{ block.settings.text }}
            </p>
          {%- endif -%}
          
          {%- if block.settings.button_label != blank and block.settings.button_link != blank -%}
            <a href="{{ block.settings.button_link }}" class="inline-block bg-white text-black px-9 py-3.5 text-[12px] font-bold tracking-wide uppercase shadow-[0_4px_15px_rgba(0,0,0,0.05)] hover:shadow-[0_6px_20px_rgba(0,0,0,0.1)] hover:-translate-y-1 transition-all duration-300">
              {{ block.settings.button_label }}
            </a>
          {%- endif -%}
        </div>

      </div>
    {%- endfor -%}
  </div>

</div>

{% schema %}
{
  "name": "Promo Banners",
  "max_blocks": 2,
  "settings": [
    {
      "type": "header",
      "content": "Banner Sizing"
    },
    {
      "type": "range",
      "id": "desktop_height",
      "min": 300,
      "max": 1000,
      "step": 10,
      "unit": "px",
      "label": "Desktop Height",
      "default": 450
    },
    {
      "type": "range",
      "id": "mobile_height",
      "min": 250,
      "max": 800,
      "step": 10,
      "unit": "px",
      "label": "Mobile Height",
      "default": 380
    },
    {
      "type": "header",
      "content": "Trust Bar Content"
    },
    { "type": "text", "id": "trust1_title", "label": "Column 1 Title", "default": "Free Shipping" },
    { "type": "text", "id": "trust1_text", "label": "Column 1 Text", "default": "Free Shipping for orders over $130" },
    { "type": "text", "id": "trust2_title", "label": "Column 2 Title", "default": "Returns" },
    { "type": "text", "id": "trust2_text", "label": "Column 2 Text", "default": "Within 30 days for an exchange." },
    { "type": "text", "id": "trust3_title", "label": "Column 3 Title", "default": "Online Support" },
    { "type": "text", "id": "trust3_text", "label": "Column 3 Text", "default": "24 hours a day, 7 days a week" },
    { "type": "text", "id": "trust4_title", "label": "Column 4 Title", "default": "Flexible Payment" },
    { "type": "text", "id": "trust4_text", "label": "Column 4 Text", "default": "Pay with Multiple Credit Cards" }
  ],
  "blocks": [
    {
      "type": "banner",
      "name": "Promo Banner",
      "settings": [
        {
          "type": "color",
          "id": "bg_color",
          "label": "Background Color",
          "default": "#f4f4f4"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Banner Image"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow Label",
          "default": "NEW COLLECTION"
        },
        {
          "type": "textarea",
          "id": "heading",
          "label": "Heading",
          "default": "Intensive Glow C+\nSerum"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Description Text",
          "default": "Makeup with extended range in colors for every human."
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button Label",
          "default": "Explore More"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Promo Banners",
      "blocks": [
        { "type": "banner" },
        { "type": "banner" }
      ]
    }
  ]
}
{% endschema %}