    { "type": "text", "id": "col2_link4_label",   "label": "Link 4 label",   "default": "Self-hosting" },
    { "type": "url",  "id": "col2_link4_url",     "label": "Link 4 URL" },
    { "type": "text", "id": "col2_link5_label",   "label": "Link 5 label" },
    { "type": "url",  "id": "col2_link5_url",     "label": "Link 5 URL" },
