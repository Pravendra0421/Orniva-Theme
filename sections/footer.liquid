{%- liquid
  assign col1_title = section.settings.col1_title | default: 'Products'
  assign col2_title = section.settings.col2_title | default: 'Solutions'
  assign col3_title = section.settings.col3_title | default: 'Resources'
  assign col4_title = section.settings.col4_title | default: 'Developers'
  assign col5_title = section.settings.col5_title | default: 'Company'
  assign brand_name = section.settings.brand_name | default: shop.name
  assign cta1_label = section.settings.cta1_label | default: 'Start For Free'
  assign cta1_url   = section.settings.cta1_url   | default: '#'
  assign cta2_label = section.settings.cta2_label | default: 'Book a Demo'
  assign cta2_url   = section.settings.cta2_url   | default: '#'
-%}

<footer class="bg-[#161616] w-full overflow-hidden">
  <div class="max-w-[1400px] mx-auto px-6 sm:px-10 lg:px-14 pt-16 pb-12">
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-10 lg:gap-6">

      <div>
        <p class="text-[#666] text-[10px] font-medium tracking-[0.2em] uppercase mb-5">{{ col1_title }}</p>
        <ul class="flex flex-col gap-3">
          {%- for i in (1..6) -%}
            {%- assign lbl = 'col1_link' | append: i | append: '_label' -%}
            {%- assign url = 'col1_link' | append: i | append: '_url'   -%}
            {%- if section.settings[lbl] != blank -%}
              <li>
                <a href="{{ section.settings[url] | default: '#' }}"
                   class="text-[#e8e4d8] text-2xl font-medium hover:text-white transition-colors duration-200 leading-tight block">
                  {{ section.settings[lbl] }}
                </a>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </div>

      <div>
        <p class="text-[#666] text-[10px] font-medium tracking-[0.2em] uppercase mb-5">{{ col2_title }}</p>
        <ul class="flex flex-col gap-3">
          {%- for i in (1..6) -%}
            {%- assign lbl = 'col2_link' | append: i | append: '_label' -%}
            {%- assign url = 'col2_link' | append: i | append: '_url'   -%}
            {%- if section.settings[lbl] != blank -%}
              <li>
                <a href="{{ section.settings[url] | default: '#' }}"
                   class="text-[#e8e4d8] text-2xl font-medium hover:text-white transition-colors duration-200 leading-tight block">
                  {{ section.settings[lbl] }}
                </a>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </div>

      <div>
        <p class="text-[#666] text-[10px] font-medium tracking-[0.2em] uppercase mb-5">{{ col3_title }}</p>
        <ul class="flex flex-col gap-3">
          {%- for i in (1..6) -%}
            {%- assign lbl = 'col3_link' | append: i | append: '_label' -%}
            {%- assign url = 'col3_link' | append: i | append: '_url'   -%}
            {%- if section.settings[lbl] != blank -%}
              <li>
                <a href="{{ section.settings[url] | default: '#' }}"
                   class="text-[#e8e4d8] text-2xl font-medium hover:text-white transition-colors duration-200 leading-tight block">
                  {{ section.settings[lbl] }}
                </a>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </div>

      <div>
        <p class="text-[#666] text-[10px] font-medium tracking-[0.2em] uppercase mb-5">{{ col4_title }}</p>
        <ul class="flex flex-col gap-3">
          {%- for i in (1..6) -%}
            {%- assign lbl = 'col4_link' | append: i | append: '_label' -%}
            {%- assign url = 'col4_link' | append: i | append: '_url'   -%}
            {%- if section.settings[lbl] != blank -%}
              <li>
                <a href="{{ section.settings[url] | default: '#' }}"
                   class="text-[#e8e4d8] text-2xl font-medium hover:text-white transition-colors duration-200 leading-tight block">
                  {{ section.settings[lbl] }}
                </a>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </div>

      <div>
        <p class="text-[#666] text-[10px] font-medium tracking-[0.2em] uppercase mb-5">{{ col5_title }}</p>
        <ul class="flex flex-col gap-3 mb-8">
          {%- for i in (1..4) -%}
            {%- assign lbl = 'col5_link' | append: i | append: '_label' -%}
            {%- assign url = 'col5_link' | append: i | append: '_url'   -%}
            {%- if section.settings[lbl] != blank -%}
              <li>
                <a href="{{ section.settings[url] | default: '#' }}"
                   class="text-[#e8e4d8] text-2xl font-medium hover:text-white transition-colors duration-200 leading-tight block">
                  {{ section.settings[lbl] }}
                </a>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
        <ul class="flex flex-col gap-2">
          {%- if section.settings.legal1_label != blank -%}
            <li><a href="{{ section.settings.legal1_url | default: '#' }}" class="text-[#555] text-[10px] font-medium tracking-[0.15em] uppercase hover:text-[#999] transition-colors duration-200">{{ section.settings.legal1_label }}</a></li>
          {%- endif -%}
          {%- if section.settings.legal2_label != blank -%}
            <li><a href="{{ section.settings.legal2_url | default: '#' }}" class="text-[#555] text-[10px] font-medium tracking-[0.15em] uppercase hover:text-[#999] transition-colors duration-200">{{ section.settings.legal2_label }}</a></li>
          {%- endif -%}
          {%- if section.settings.legal3_label != blank -%}
            <li><a href="{{ section.settings.legal3_url | default: '#' }}" class="text-[#555] text-[10px] font-medium tracking-[0.15em] uppercase hover:text-[#999] transition-colors duration-200">{{ section.settings.legal3_label }}</a></li>
          {%- endif -%}
        </ul>

        <p class="text-[#444] text-[10px] font-medium tracking-[0.12em] uppercase mt-6">
          &copy; {{ brand_name }} {{ 'now' | date: '%Y' }}
        </p>
      </div>

    </div>
  </div>

  <div class="w-full overflow-hidden leading-none pointer-events-none select-none" aria-hidden="true">
    <p class="text-[#e8e4d8] font-black uppercase tracking-tight whitespace-nowrap
              text-[20vw] leading-[0.82] px-6 sm:px-10 lg:px-14 mb-20">
      {{ brand_name }}
    </p>
  </div>

</footer>

{% schema %}
{
  "name": "Retool Footer",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Brand"
    },
    {
      "type": "text",
