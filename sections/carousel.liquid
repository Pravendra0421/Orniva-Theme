{%- liquid
  assign total = section.blocks.size
-%}
<section
  id="carousel-{{ section.id }}"
  class="relative w-full bg-neutral-100 py-16 overflow-hidden"
  role="region"
  aria-roledescription="carousel"
  aria-label="{{ section.settings.section_label }}"
>
  {% if section.settings.heading != blank %}
    <div class="text-center mb-10 px-6">
      <p class="text-xs uppercase tracking-widest text-neutral-400">
        {{ section.settings.eyebrow }}
      </p>
      <h2 class="text-3xl md:text-5xl font-serif text-neutral-800">
        {{ section.settings.heading }}
      </h2>
    </div>
  {% endif %}
  <div
    class="relative flex items-center justify-center h-[520px]"
    data-carousel
  >
    {% for block in section.blocks %}
      <article
        class="carousel-item absolute w-[260px] h-[420px] rounded-2xl overflow-hidden transition-all duration-500 ease-out opacity-0"
        data-index="{{ forloop.index0 }}"
        role="group"
        aria-roledescription="slide"
        aria-label="Slide {{ forloop.index }} of {{ total }}"
        tabindex="-1"
        {{ block.shopify_attributes }}
      >
        {% if block.settings.card_image %}
          <img
            src="{{ block.settings.card_image | image_url: width: 600 }}"
            srcset="
                {{ block.settings.card_image | image_url: width: 300 }} 300w,
                {{ block.settings.card_image | image_url: width: 600 }} 600w
            "
            sizes="(max-width: 768px) 80vw, 400px"
            alt="{{ block.settings.card_label | escape }}"
            class="w-full h-full object-cover"
            loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
            fetchpriority="{% if forloop.first %}high{% else %}low{% endif %}"
            decoding="async"
            >
        {% endif %}
        <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
        {% if block.settings.card_label %}
          <div class="absolute bottom-4 w-full text-center">
            <span class="text-white text-xs uppercase tracking-widest bg-black/40 px-4 py-2 rounded">
              {{ block.settings.card_label }}
            </span>
          </div>
        {% endif %}
      </article>
    {% endfor %}
    <button
      class="carousel-prev absolute left-6 z-50 w-10 h-10 bg-white rounded-full shadow"
      aria-label="Previous slide"
    >‹</button>
    <button
      class="carousel-next absolute right-6 z-50 w-10 h-10 bg-white rounded-full shadow"
      aria-label="Next slide"
    >›</button>
  </div>
  <div class="flex justify-center gap-2 mt-6">
    {% for block in section.blocks %}
      <button
        class="carousel-dot w-2 h-2 bg-neutral-300 rounded-full"
        data-index="{{ forloop.index0 }}"
        aria-label="Go to slide {{ forloop.index }}"
      ></button>
    {% endfor %}
  </div>
</section>
<script>
(function(){
  const root = document.querySelector('#carousel-{{ section.id }}');
  if(!root) return;

  const items = root.querySelectorAll('.carousel-item');
  const dots = root.querySelectorAll('.carousel-dot');
  const prev = root.querySelector('.carousel-prev');
  const next = root.querySelector('.carousel-next');

  let current = 0;
  const total = items.length;

  function update(){
    items.forEach((el,i)=>{
      let offset = i - current;

      if(offset > total/2) offset -= total;
      if(offset < -total/2) offset += total;

      let transform = '';
      let opacity = 0;
      let z = 10;

      if(offset === 0){
        transform = 'translateX(0) scale(1)';
        opacity = 1;
        z = 30;
        el.setAttribute('tabindex','0');
      } else if(offset === -1){
        transform = 'translateX(-180px) rotateY(25deg) scale(.85)';
        opacity = .7;
        z = 20;
      } else if(offset === 1){
        transform = 'translateX(180px) rotateY(-25deg) scale(.85)';
        opacity = .7;
        z = 20;
      }

      el.style.transform = transform;
      el.style.opacity = opacity;
      el.style.zIndex = z;
    });

    dots.forEach((d,i)=>{
      d.classList.toggle('bg-black', i === current);
    });
  }

  function go(i){
    current = (i + total) % total;
    update();
  }

  prev.addEventListener('click', ()=>go(current-1));
  next.addEventListener('click', ()=>go(current+1));

  dots.forEach(d=>{
    d.addEventListener('click', ()=>go(+d.dataset.index));
  });
  root.addEventListener('keydown', (e)=>{
    if(e.key === 'ArrowRight') go(current+1);
    if(e.key === 'ArrowLeft') go(current-1);
  });
  update();
})();
</script>
{% schema %}
{
  "name": "Carousel",
  "settings": [
    { "type": "text", "id": "section_label", "label": "ARIA Label", "default": "Carousel" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading" }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        { "type": "image_picker", "id": "card_image", "label": "Image" },
        { "type": "text", "id": "card_label", "label": "Label" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Carousel",
      "blocks": [{ "type": "card" }, { "type": "card" }, { "type": "card" }]
    }
  ]
}
{% endschema %}