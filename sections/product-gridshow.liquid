{% liquid
  assign card_blocks = section.blocks | where: 'type', 'card'
%}

<section class="w-full bg-white px-4 md:px-8 lg:px-12 py-14 md:py-20">
  {% if section.settings.heading != blank %}
    <div class="text-center mb-10 md:mb-16">
      <h2 class="text-3xl md:text-5xl text-neutral-900 font-light">
        {{ section.settings.heading }}
      </h2>
    </div>
  {% endif %}
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-5">

    {% for block in section.blocks %}
      {% if block.type == 'card' %}

        {% liquid
          assign product = all_products[block.settings.product]
          assign is_even = forloop.index | modulo: 2
        %}

        {% if product != blank %}
          <a
            href="{{ product.url }}"
            class="group block {% if is_even == 0 %}mt-0 sm:mt-12 md:mt-20{% endif %}"
            {{ block.shopify_attributes }}
          >

            <div class="flex flex-col gap-4">

              <div class="relative overflow-hidden aspect-[3/4] {% if is_even == 0 %}order-2{% endif %}">

                {% if product.featured_image != blank %}
                  <img
                    src="{{ product.featured_image | image_url: width: 600 }}"
                    srcset="
                      {{ product.featured_image | image_url: width: 300 }} 300w,
                      {{ product.featured_image | image_url: width: 600 }} 600w,
                      {{ product.featured_image | image_url: width: 900 }} 900w
                    "
                    sizes="(max-width: 768px) 100vw, 25vw"
                    alt="{{ product.title | escape }}"
                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                    loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                    fetchpriority="{% if forloop.first %}high{% else %}low{% endif %}"
                    width="600"
                    height="800"
                  >
                {% endif %}

              </div>
              <div class="{% if is_even == 0 %}order-1{% endif %} px-1">

                <h3 class="text-lg md:text-xl text-neutral-900">
                  {{ product.title }}
                </h3>

                {% if block.settings.subtitle != blank %}
                  <p class="text-sm text-neutral-500">
                    {{ block.settings.subtitle }}
                  </p>
                {% endif %}

                <span class="inline-flex items-center gap-1 text-sm uppercase tracking-wide mt-2 border-b border-neutral-900 group-hover:gap-2 transition-all duration-300">
                  {{ block.settings.cta_label }}
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none" class="transition-transform duration-300 group-hover:translate-x-1">
                    <path d="M3 7h8M8 4l3 3-3 3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>

              </div>

            </div>

          </a>
        {% endif %}

      {% endif %}
    {% endfor %}

  </div>

</section>

{% schema %}
{
  "name": "Product-gridshow",
  "tag": "section",
  "class": "occasion-grid-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Designed for Every Moment"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Product Card",
      "limit": 4,
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select Product"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "Styles for every occasion"
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "CTA Label",
          "default": "Explore"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Occasion Grid",
      "blocks": [
        { "type": "card" },
        { "type": "card" },
        { "type": "card" },
        { "type": "card" }
      ]
    }
  ]
}
{% endschema %}