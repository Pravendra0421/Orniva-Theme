<section class="w-full bg-[#faf9f7] min-h-screen py-16 px-5 sm:px-8 lg:px-14">
  <div class="max-w-[1520px] mx-auto mb-12 sm:mb-16">
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">
      <div>
        <p class="text-[10px] font-medium tracking-[0.35em] uppercase text-black mb-3">
          {{ section.settings.eyebrow | default: 'Browse' }}
        </p>
        <h1 class="font-serif italic font-light text-black leading-none tracking-tight
                   text-[2.2rem] sm:text-[3rem] lg:text-[3.8rem]">
          {{ section.settings.heading | default: 'All Collections' }}
        </h1>
      </div>
      {%- if section.settings.show_count -%}
        <p class="text-[11px] font-light tracking-[0.2em] uppercase text-[#6e6558]">
          {{ collections.size }} Collections
        </p>
      {%- endif -%}
    </div>
    <div class="mt-6 h-px w-full bg-gradient-to-r from-[rgba(201,169,110,0.3)] to-transparent"></div>
  </div>
  <div class="max-w-[1520px] mx-auto
              grid gap-4 sm:gap-5 lg:gap-6
              grid-cols-1
              sm:grid-cols-2
              {% if section.settings.grid_columns == '3' %}
                lg:grid-cols-3
              {% elsif section.settings.grid_columns == '4' %}
                lg:grid-cols-3 xl:grid-cols-4
              {% else %}
                lg:grid-cols-2
              {% endif %}
              ">

    {%- for collection in collections -%}

      {%- comment -%} Tall card for first item if featured layout enabled {%- endcomment -%}
      {%- assign is_featured = false -%}
      {%- if section.settings.featured_first and forloop.index == 1 -%}
        {%- assign is_featured = true -%}
      {%- endif -%}

      <a
        href="{{ collection.url }}"
        class="group relative block overflow-hidden bg-[#161410]
               {% if is_featured %}sm:col-span-2 sm:row-span-2{% endif %}
               focus-visible:outline focus-visible:outline-2 focus-visible:outline-[#c9a96e] focus-visible:outline-offset-2"
        aria-label="{{ collection.title | escape }}"
      >
        <div class="relative w-full overflow-hidden
                    {% if is_featured %}aspect-[4/3] sm:aspect-[3/2]{% else %}aspect-[4/3]{% endif %}
                    bg-[#1c1a16]">

          {%- if collection.featured_image -%}
            <img
              src="{{ collection.featured_image | image_url: width: 800 }}"
              srcset="{{ collection.featured_image | image_url: width: 400 }} 400w,
                      {{ collection.featured_image | image_url: width: 600 }} 600w,
                      {{ collection.featured_image | image_url: width: 800 }} 800w,
                      {{ collection.featured_image | image_url: width: 1200 }} 1200w"
              sizes="(max-width:640px) 100vw, (max-width:1024px) 50vw, 33vw"
              alt="{{ collection.featured_image.alt | escape | default: collection.title | escape }}"
              width="800" height="600"
              loading="{% if forloop.index <= 2 %}eager{% else %}lazy{% endif %}"
              fetchpriority="{% if forloop.index == 1 %}high{% else %}auto{% endif %}"
              decoding="async"
              class="w-full h-full object-cover object-center
                     transition-transform duration-700 ease-out
                     group-hover:scale-[1.06]"
            >
          {%- else -%}
            {%- comment -%} Elegant placeholder when no image {%- endcomment -%}
            <div class="w-full h-full flex items-center justify-center bg-[#1c1a16]">
              <svg class="w-12 h-12 text-[#3a3630]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1"
                      d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
            </div>
          {%- endif -%}
          <div class="absolute inset-0 bg-gradient-to-t
                      from-black/70 via-black/20 to-transparent
                      pointer-events-none"></div>
          <div class="absolute inset-0 bg-black/25 opacity-0 group-hover:opacity-100
                      transition-opacity duration-400 pointer-events-none"></div>
          {%- if section.settings.show_product_count and collection.products_count > 0 -%}
            <div class="absolute top-3 right-3 pointer-events-none">
              <span class="bg-[rgba(15,14,12,0.75)] backdrop-blur-sm
                           border border-[rgba(201,169,110,0.25)]
                           text-[#c9a96e] text-[9px] font-medium tracking-[0.18em] uppercase
                           px-2.5 py-1 leading-none">
                {{ collection.products_count }}
                {%- if collection.products_count == 1 -%} Item{%- else -%} Items{%- endif -%}
              </span>
            </div>
          {%- endif -%}
          <div class="absolute inset-x-0 bottom-0 p-5 sm:p-6">

            <div class="flex items-end justify-between gap-4">
              <div class="flex-1 min-w-0">

                <h2 class="font-serif font-light text-[#f0ead8] leading-tight tracking-tight
                           {% if is_featured %}text-2xl sm:text-3xl{% else %}text-xl sm:text-2xl{% endif %}">
                  {{ collection.title }}
                </h2>

                {%- if collection.description != blank and section.settings.show_description -%}
                  <p class="text-[12px] font-light text-[#a09080] leading-relaxed mt-1.5 line-clamp-2
                             max-h-0 overflow-hidden opacity-0
                             group-hover:max-h-20 group-hover:opacity-100
                             transition-all duration-500 ease-out">
                    {{ collection.description | strip_html | truncatewords: 14 }}
                  </p>
                {%- endif -%}

              </div>

              <div class="flex-none w-9 h-9 flex items-center justify-center
                          border border-[rgba(201,169,110,0.3)]
                          text-[#c9a96e]
                          group-hover:border-[#c9a96e] group-hover:bg-[rgba(201,169,110,0.1)]
                          transition-all duration-300 shrink-0">
                <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-0.5"
                     fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                        d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </div>

            </div>
          </div>

        </div>

      </a>

    {%- else -%}
      <div class="col-span-full py-20 text-center">
        <p class="text-[#6e6558] text-sm tracking-widest uppercase">No collections found.</p>
      </div>
    {%- endfor -%}

  </div>

</section>

{% schema %}
{
  "name": "Collections Grid",
  "settings": [
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Browse"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Page heading",
      "default": "All Collections"
    },
    {
      "type": "checkbox",
      "id": "show_count",
      "label": "Show total collection count",
      "default": true
    },
    {
      "type": "header",
      "content": "Grid Layout"
    },
    {
      "type": "select",
      "id": "grid_columns",
      "label": "Columns on desktop",
      "options": [
        { "value": "2", "label": "2 columns" },
        { "value": "3", "label": "3 columns" },
        { "value": "4", "label": "4 columns" }
      ],
      "default": "3"
    },
    {
      "type": "checkbox",
      "id": "featured_first",
      "label": "Make first collection card large (2×2)",
      "default": true
    },
    {
      "type": "header",
      "content": "Card Options"
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show description on hover",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_product_count",
      "label": "Show product count badge",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Collections Grid"
    }
  ]
}
{% endschema %}
